# Copy this file to .env.local and fill in to go live, then restart `npm run dev` (or redeploy).
# All are PUBLIC (sent to the browser) — fine for these keys. Blank = demo mode.

# Required for the quote form to actually email leads. Free key at https://web3forms.com
NEXT_PUBLIC_WEB3FORMS_KEY=

# Every lead is also CC'd here (in addition to the Web3Forms account inbox).
# Defaults to cleaningandpaintingingeneral@gmail.com if left blank.
NEXT_PUBLIC_LEAD_EMAIL=cleaningandpaintingingeneral@gmail.com

# Analytics / Google Ads conversion tracking (optional until you run ads)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_ADS_ID=
NEXT_PUBLIC_ADS_LEAD_LABEL=
NEXT_PUBLIC_ADS_CALL_LABEL=

# Your Google Business "reviews"/"write a review" link (falls back to a Google search)
NEXT_PUBLIC_GOOGLE_PROFILE_URL=
